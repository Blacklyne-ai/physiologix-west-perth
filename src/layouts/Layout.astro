---
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FloatingCTA from '../components/FloatingCTA.astro';
import CookieBanner from '../components/CookieBanner.astro';
import AcknowledgementOfCountry from '../components/AcknowledgementOfCountry.astro';

interface Props {
  title: string;
  description: string;
  path?: string;
  image?: string;
  type?: string;
  schema?: object | object[];
  noindex?: boolean;
}
const props = Astro.props;
---

<!doctype html>
<html lang="en-AU">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#2a3d33" />
    <meta name="generator" content={Astro.generator} />
    <SEO {...props} />
  </head>
  <body>
    <!-- Branded intro (first visit of session only) -->
    <div data-preloader class="preloader" aria-hidden="true">
      <div class="preloader-inner">
        <span class="preloader-word font-display">PHYSIOLOGI<span class="text-sage">X</span></span>
        <span class="preloader-tag font-display italic">Physiotherapy at the Speed of Life</span>
        <div class="preloader-rail"><span data-pre-bar class="preloader-bar"></span></div>
        <span data-pre-count class="preloader-count tnum">0</span>
      </div>
    </div>
    <script is:inline>
      (() => {
        const pre = document.querySelector('[data-preloader]');
        if (!pre) return;
        const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
        let seen = false;
        try { seen = sessionStorage.getItem('plx-intro') === '1'; } catch (e) {}
        if (seen || reduced) { pre.remove(); return; }
        try { sessionStorage.setItem('plx-intro', '1'); } catch (e) {}
        document.documentElement.classList.add('preloading');
        const bar = pre.querySelector('[data-pre-bar]');
        const count = pre.querySelector('[data-pre-count]');
        const dur = 1250, t0 = performance.now();
        let finished = false;
        const done = () => {
          if (finished) return; finished = true;
          pre.classList.add('is-done');
          document.documentElement.classList.remove('preloading');
          setTimeout(() => pre.remove(), 1000);
          window.dispatchEvent(new Event('plx:intro-done'));
        };
        const tick = (now) => {
          const p = Math.min((now - t0) / dur, 1);
          if (bar) bar.style.transform = 'scaleX(' + p + ')';
          if (count) count.textContent = Math.round(p * 100);
          if (p < 1) requestAnimationFrame(tick); else done();
        };
        requestAnimationFrame(tick);
        setTimeout(() => { if (document.body.contains(pre)) done(); }, 3800);
      })();
    </script>

    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-[100] focus:px-4 focus:py-2 focus:rounded-full focus:bg-forest focus:text-cream">Skip to main content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <AcknowledgementOfCountry />
    <Footer />
    <FloatingCTA />
    <CookieBanner />
    <script>
      import '../scripts/motion.ts';
    </script>
  </body>
</html>
