---
import AudiencePage from '../components/AudiencePage.astro';
---
<AudiencePage
  seoTitle="NDIS Physiotherapy West Perth"
  description="Physiotherapy for NDIS participants in West Perth. Goal-focused, clearly documented care for NDIA-managed, plan-managed and self-managed participants."
  path="/ndis"
  eyebrow="NDIS participants"
  title="Physiotherapy that works toward"
  accent="your goals."
  lead="We support NDIS participants and plan managers. Our physiotherapy is goal-focused and clearly documented — built to support the outcomes set out in your plan."
  crumbs={[{ label: 'NDIS' }]}
  intro={[
    "If physiotherapy is part of your NDIS plan, we can help you work toward greater independence, mobility and participation. Treatment is individualised, evidence-based and progressed at a pace that suits you.",
    "We keep clear documentation so reporting against your plan goals is straightforward, and we work alongside your support coordinator or plan manager.",
    "We support NDIA-managed, plan-managed and self-managed participants. Get in touch and we'll walk you through how claiming works for your plan.",
  ]}
  checklistHeading="How we support you"
  checklist={[
    'Goal-focused physiotherapy aligned to your plan',
    'Clear documentation and progress notes',
    'Coordination with support coordinators and plan managers',
    'NDIA-managed, plan-managed and self-managed participants welcome',
  ]}
  highlights={[
    { t: 'Independence-focused', d: 'Care built around mobility, function and participation goals.', icon: 'physio' },
    { t: 'Plan-friendly records', d: 'Documentation that makes reporting against your goals simple.', icon: 'shield' },
    { t: 'Founder-led care', d: 'Vincent personally builds and reviews your plan.', icon: 'cap' },
  ]}
  ctaHeading="Let's work toward"
  ctaAccent="your goals."
  ctaSub="Get in touch and we'll walk you through how NDIS claiming works for your plan."
  primaryCtaLabel="Enquire about NDIS"
/>
