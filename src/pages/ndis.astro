---
import AudiencePage from '../components/AudiencePage.astro';
---
<AudiencePage
  seoTitle="NDIS Physiotherapy West Perth"
  description="Physiotherapy for NDIS participants in West Perth. Clear, goal-focused care that supports the outcomes in your plan. Registration status to be confirmed."
  path="/ndis"
  eyebrow="NDIS participants"
  title="Physiotherapy that works toward"
  accent="your goals."
  lead="We welcome NDIS participants and plan managers. Our physiotherapy is goal-focused and clearly documented — built to support the outcomes set out in your plan."
  crumbs={[{ label: 'NDIS' }]}
  intro={[
    "If physiotherapy is part of your NDIS plan, we can help you work toward greater independence, mobility and participation. Treatment is individualised, evidence-based and progressed at a pace that suits you.",
    "We keep clear documentation so reporting against your plan goals is straightforward, and we're happy to work alongside your support coordinator or plan manager.",
    "Please contact us to confirm registration status and how claiming works for your situation — whether you're self-managed, plan-managed or NDIA-managed.",
  ]}
  checklistHeading="How we support you"
  checklist={[
    'Goal-focused physiotherapy aligned to your plan',
    'Clear documentation and progress notes',
    'Coordination with support coordinators and plan managers',
    'Self-managed and plan-managed participants welcome',
    'Registration status to be confirmed',
  ]}
  note="NDIS provider registration status to be confirmed by the client."
  highlights={[
    { t: 'Independence-focused', d: 'Care built around mobility, function and participation goals.', icon: 'physio' },
    { t: 'Plan-friendly records', d: 'Documentation that makes reporting against your goals simple.', icon: 'shield' },
    { t: 'Founder-led care', d: 'Vincent personally builds and reviews your plan.', icon: 'cap' },
  ]}
  ctaHeading="Let's work toward"
  ctaAccent="your goals."
  ctaSub="Get in touch to confirm how NDIS claiming works for your plan."
  primaryCtaLabel="Enquire about NDIS"
/>
