---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import { site } from '../data/site';
---

<Layout
  title="Contact"
  description="Contact PhysioLogix in West Perth. Call 0450 075 955, book online via Cliniko, or visit us at 6/567 Newcastle St. Opening hours, parking and directions."
  path="/contact"
>
  <PageHero
    eyebrow="Get in touch"
    title="Visit us in"
    accent="West Perth."
    lead="Book online any time through Cliniko, give us a call, or send a message below and we'll get back to you."
    crumbs={[{ label: 'Contact' }]}
  />

  <section class="bg-ivory section">
    <div class="container-page grid lg:grid-cols-2 gap-10 lg:gap-16">
      <!-- Details -->
      <div>
        <div class="grid sm:grid-cols-2 gap-5 reveal">
          <a href={`tel:${site.phoneHref}`} class="card card-hover p-6 block">
            <p class="eyebrow text-forest/60 mb-1">Call</p>
            <p class="font-display font-bold text-xl text-forest">{site.phoneDisplay}</p>
          </a>
          <a href={`mailto:${site.email}`} class="card card-hover p-6 block">
            <p class="eyebrow text-forest/60 mb-1">Email</p>
            <p class="font-display font-bold text-lg text-forest break-words">{site.email}</p>
          </a>
        </div>

        <div class="card p-6 mt-5 reveal">
          <p class="eyebrow text-forest/60 mb-1">Visit</p>
          <address class="not-italic font-display font-bold text-xl text-forest">{site.address.full}</address>
          <p class="mt-2 text-sm text-charcoal/70">On the Newcastle Street artery between West Perth and Northbridge.</p>
          <a href={site.booking} target="_blank" rel="noopener" class="btn btn-primary mt-5 w-full sm:w-auto" data-ripple>Book online via Cliniko</a>
        </div>

        <div class="card p-6 mt-5 reveal">
          <p class="eyebrow text-forest/60 mb-3">Opening hours</p>
          <ul class="space-y-1.5 text-sm">
            {site.hours.map((h) => (
              <li class="flex justify-between border-b border-forest/5 pb-1.5 last:border-0">
                <span class="text-charcoal/80">{h.day}</span>
                <span class={h.open ? 'text-forest font-medium tnum' : 'text-warmgrey'}>{h.time}</span>
              </li>
            ))}
          </ul>
          <p class="mt-3 text-xs text-warmgrey">Hours to be confirmed with the clinic. Please check before visiting.</p>
        </div>

        <div class="grid sm:grid-cols-2 gap-5 mt-5 reveal">
          <div class="card p-6">
            <p class="eyebrow text-forest/60 mb-1">Parking</p>
            <p class="text-sm text-charcoal/75">Street and nearby parking available. Details to be confirmed — please ask when booking.</p>
          </div>
          <div class="card p-6">
            <p class="eyebrow text-forest/60 mb-1">Public transport</p>
            <p class="text-sm text-charcoal/75">Bus routes run along Newcastle Street, with train stations a short walk away.</p>
          </div>
        </div>
      </div>

      <!-- Form + map -->
      <div>
        <form class="card p-7 reveal" name="contact" method="POST" data-contact-form>
          <h2 class="font-display font-bold text-2xl text-forest mb-1">Send a message</h2>
          <p class="text-sm text-charcoal/65 mb-5">We aim to reply within one business day.</p>

          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label for="name" class="block text-sm font-semibold text-forest mb-1.5">Name</label>
              <input id="name" name="name" type="text" required autocomplete="name" class="w-full rounded-xl px-4 py-3" />
            </div>
            <div>
              <label for="phone" class="block text-sm font-semibold text-forest mb-1.5">Phone</label>
              <input id="phone" name="phone" type="tel" autocomplete="tel" class="w-full rounded-xl px-4 py-3" />
            </div>
          </div>
          <div class="mt-4">
            <label for="email" class="block text-sm font-semibold text-forest mb-1.5">Email</label>
            <input id="email" name="email" type="email" required autocomplete="email" class="w-full rounded-xl px-4 py-3" />
          </div>
          <div class="mt-4">
            <label for="reason" class="block text-sm font-semibold text-forest mb-1.5">Reason for enquiry</label>
            <select id="reason" name="reason" class="w-full rounded-xl px-4 py-3">
              <option>Book an appointment</option>
              <option>General enquiry</option>
              <option>Insurance / claims question</option>
              <option>NDIS / DVA enquiry</option>
              <option>Join the team</option>
              <option>Other</option>
            </select>
          </div>
          <div class="mt-4">
            <label for="message" class="block text-sm font-semibold text-forest mb-1.5">Message</label>
            <textarea id="message" name="message" rows="4" required class="w-full rounded-xl px-4 py-3"></textarea>
          </div>
          <button type="submit" class="btn btn-primary w-full mt-5" data-magnetic data-ripple>Send message</button>
          <p class="mt-3 text-xs text-warmgrey">By submitting this form you consent to PhysioLogix contacting you about your enquiry. See our <a href="/privacy-policy" class="text-forest underline underline-offset-2">Privacy Policy</a>.</p>
          <p class="mt-2 text-xs text-orange">Form endpoint to be connected (e.g. Formspree / Cloudflare). Until then, please call or email.</p>
        </form>

        <div class="mt-5 rounded-3xl overflow-hidden shadow-xl border border-forest/10 reveal">
          <iframe
            title="PhysioLogix location map"
            src={`https://www.google.com/maps?q=${site.address.mapsQuery}&output=embed`}
            class="w-full h-[320px]"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  <script>
    document.querySelector('[data-contact-form]')?.addEventListener('submit', (e) => {
      e.preventDefault();
      alert('Thanks! This form needs its endpoint connected before launch. For now, please call 0450 075 955 or email us.');
    });
  </script>
</Layout>
