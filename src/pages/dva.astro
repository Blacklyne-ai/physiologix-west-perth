---
import AudiencePage from '../components/AudiencePage.astro';
---
<AudiencePage
  seoTitle="DVA Physiotherapy West Perth"
  description="Physiotherapy for Department of Veterans' Affairs (DVA) cardholders in West Perth. Bring your card and GP referral - we handle the rest."
  path="/dva"
  eyebrow="Veterans' care"
  title="Care for those who"
  accent="served."
  lead="We welcome Department of Veterans' Affairs (DVA) cardholders. With a referral from your GP, eligible veterans can access physiotherapy under DVA arrangements."
  crumbs={[{ label: 'DVA' }]}
  intro={[
    "Perth is home to a significant veteran community, and we're proud to support DVA cardholders with the same diagnostic-first physiotherapy we provide every patient.",
    "DVA-funded physiotherapy generally requires a referral (D904) from your GP. Bring your card and referral and we'll take care of the rest.",
    "Whether you hold a Gold or White card, get in touch and we'll let you know what's covered and book you in.",
  ]}
  checklistHeading="What to bring"
  checklist={[
    'Your DVA card (Gold or White)',
    'A current GP referral (D904) where required',
    'Any relevant scans or reports',
  ]}
  highlights={[
    { t: 'Respectful, personal care', d: 'One clinician, one plan — built around your history and goals.', icon: 'physio' },
    { t: 'Referral-friendly', d: 'We work with your GP and the DVA referral process.', icon: 'shield' },
    { t: 'Whole-person approach', d: 'Diagnostic-first treatment that looks beyond the symptom.', icon: 'recovery' },
  ]}
  ctaHeading="We're here to"
  ctaAccent="help."
  ctaSub="Call us about your DVA cover and book your first appointment."
  primaryCtaLabel="Enquire about DVA"
/>
