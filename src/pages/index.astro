---
import Layout from '../layouts/Layout.astro';
import ServiceIcon from '../components/ServiceIcon.astro';
import ReviewCard from '../components/ReviewCard.astro';
import Marquee from '../components/Marquee.astro';
import {
  site, services, conditions, team, reviews, reviewDisclaimer,
  stats, processSteps,
} from '../data/site';

const vincent = team[0];
const marqueeItems = [
  'Physiotherapy', 'Reformer Pilates', 'Dry Needling', 'Manual Therapy',
  'Lower Back Pain', 'Neck Pain', 'Headaches', 'Sciatica', 'Sports Injuries',
  'West Perth', 'Northbridge', 'Leederville', 'Subiaco', 'NIB Preferred Provider',
];
const description =
  'Founder-led physiotherapy, reformer pilates, dry needling and rehabilitation in West Perth. Vincent Harvey personally treats every initial assessment. 5.0★ from 81 Google reviews. Book online.';
---

<Layout title="Physiotherapy West Perth" description={description} path="/">
  <!-- ============ 1. HERO ============ -->
  <section class="relative bg-ivory overflow-hidden pt-28 md:pt-36 pb-16 md:pb-24">
    <svg class="absolute top-20 -right-20 w-[55rem] max-w-[80vw] text-sage opacity-10 pointer-events-none" viewBox="0 0 600 600" fill="none" aria-hidden="true">
      <path d="M-20 480 C200 280 300 540 640 160" stroke="currentColor" stroke-width="64" stroke-linecap="round"/>
    </svg>
    <div class="container-page relative grid lg:grid-cols-12 gap-10 lg:gap-8 items-center">
      <div class="lg:col-span-7 stagger">
        <p class="eyebrow text-forest flex flex-wrap items-center gap-x-2 gap-y-1">
          <span>AHPRA Registered</span><span class="text-sage">·</span>
          <span>West Perth</span><span class="text-sage">·</span>
          <span>5.0 ★ · 81 Google Reviews</span>
        </p>
        <h1 class="mt-5 font-display font-extrabold text-forest leading-[0.98] tracking-[-0.03em] text-[clamp(2.75rem,8vw,6rem)]">
          Physiotherapy at the <span class="accent">Speed&nbsp;of&nbsp;Life.</span>
        </h1>
        <p class="mt-7 text-lg md:text-xl text-charcoal/75 max-w-xl leading-relaxed">
          Founder-led physiotherapy, reformer pilates, dry needling and rehabilitation
          in West Perth. Vincent Harvey personally treats every initial assessment —
          because finding the real cause matters more than a quick fix.
        </p>
        <div class="mt-9 flex flex-col sm:flex-row gap-3">
          <a href={site.booking} target="_blank" rel="noopener" class="btn btn-primary text-base" data-magnetic data-ripple>Book online</a>
          <a href={`tel:${site.phoneHref}`} class="btn btn-outline text-base">Call {site.phoneDisplay}</a>
        </div>
        <p class="mt-6 text-sm text-warmgrey">
          NIB Preferred Provider · Workers Comp + MVA claims · Cliniko online booking
        </p>
      </div>

      <div class="lg:col-span-5 relative">
        <div class="relative float-photo">
          <div class="absolute -inset-4 bg-sage/25 blur-2xl rounded-[3rem]" aria-hidden="true"></div>
          <img
            src="/photos/clinic/physio-treatment.jpg"
            alt="Physiotherapist performing a gentle neck mobilisation at PhysioLogix"
            width="720" height="900"
            class="relative rounded-[2rem] shadow-2xl object-cover aspect-[4/5] w-full"
            fetchpriority="high"
          />
          <div class="absolute -bottom-5 -left-4 sm:-left-8 glass !bg-cream/90 px-5 py-3.5 shadow-xl rounded-2xl flex items-center gap-3">
            <div class="flex flex-col">
              <span class="flex items-center gap-0.5 text-sage">
                {Array.from({ length: 5 }).map(() => (<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3 6.5 7 .9-5.2 4.8 1.4 7-6.2-3.6L6 21.2l1.4-7L2.2 9.4l7-.9z"/></svg>))}
              </span>
              <span class="text-sm font-semibold text-forest tnum">5.0 · 81 Google Reviews</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ 3. TRUST BAND ============ -->
  <section class="relative -mt-6 z-10">
    <div class="container-page">
      <div class="grid md:grid-cols-3 gap-5">
        {[
          { icon: 'cap', title: '10+ Years Clinical', body: 'Founder-led care — Vincent personally treats every initial assessment.' },
          { icon: 'star', title: '5.0 ★ from 81 Reviews', body: 'The Perth physio that patients keep referring their friends to.' },
          { icon: 'shield', title: 'All Major Insurers', body: 'NIB Preferred Provider — plus HBF, Medibank, Bupa, HCF and Westfund.' },
        ].map((c) => (
          <div class="glass card-hover p-6 flex items-start gap-4 reveal">
            <span class="shrink-0 w-12 h-12 rounded-2xl bg-sage/30 text-forest grid place-items-center">
              <ServiceIcon name={c.icon} class="w-6 h-6" />
            </span>
            <div>
              <p class="font-display font-bold text-forest text-lg">{c.title}</p>
              <p class="text-sm text-charcoal/70 mt-1">{c.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ 4. PULL QUOTE ============ -->
  <section class="relative bg-night overflow-hidden mt-20 md:mt-28">
    <div class="absolute inset-0 grain opacity-[0.05]" aria-hidden="true"></div>
    <div class="container-page section text-center relative">
      <blockquote class="max-w-4xl mx-auto reveal">
        <p class="font-display italic font-medium text-cream text-3xl sm:text-4xl md:text-5xl leading-[1.15]">
          “Focused on finding the <span class="accent">real cause</span> rather than a quick fix.”
        </p>
        <footer class="mt-7 text-cream/60 text-sm">— Google review · ★★★★★</footer>
      </blockquote>
      <a href="/reviews" class="btn btn-outline mt-9 !text-cream !shadow-[inset_0_0_0_1.5px_rgba(156,192,132,0.6)] hover:!bg-sage hover:!text-night reveal">Read all reviews</a>
    </div>
  </section>

  <!-- ============ 5. SERVICES BENTO ============ -->
  <section class="bg-ivory section">
    <div class="container-page">
      <div class="max-w-2xl mb-12 reveal">
        <p class="eyebrow text-forest mb-3">What we treat with</p>
        <h2 class="font-display font-extrabold text-forest text-4xl md:text-5xl">Real treatment. <span class="accent">Real recovery.</span></h2>
      </div>

      <div class="grid md:grid-cols-4 gap-5">
        <a href="/services/physiotherapy" class="group card card-hover md:col-span-2 md:row-span-2 overflow-hidden flex flex-col reveal">
          <div class="relative h-56 md:h-72 overflow-hidden">
            <img src="/photos/clinic/physio-treatment.jpg" alt="Physiotherapy treatment" width="800" height="600" loading="lazy" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"/>
            <div class="absolute inset-0 bg-gradient-to-t from-night/70 to-transparent"></div>
          </div>
          <div class="p-7 flex-1">
            <p class="eyebrow text-sage mb-2">Founder-led · Starting point for most patients</p>
            <h3 class="font-display font-bold text-2xl text-forest">Physiotherapy</h3>
            <p class="mt-2 text-charcoal/70">Diagnostic-first physiotherapy. We find the real cause — then build a plan combining hands-on work, exercise prescription, and the techniques that actually fit your condition.</p>
            <span class="mt-4 inline-flex items-center gap-1.5 font-semibold text-forest group-hover:gap-3 transition-all">Learn more <span aria-hidden="true">→</span></span>
          </div>
        </a>

        <a href="/services/reformer-pilates" class="group card card-hover md:col-span-2 md:row-span-2 overflow-hidden flex flex-col reveal">
          <div class="relative h-56 md:h-72 overflow-hidden">
            <img src="/photos/services/reformer-pilates.jpg" alt="Clinical reformer pilates" width="800" height="600" loading="lazy" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"/>
            <div class="absolute inset-0 bg-gradient-to-t from-night/70 to-transparent"></div>
          </div>
          <div class="p-7 flex-1">
            <p class="eyebrow text-sage mb-2">Our differentiator · One-on-one with a physio</p>
            <h3 class="font-display font-bold text-2xl text-forest">Clinical Reformer Pilates</h3>
            <p class="mt-2 text-charcoal/70">Reformer pilates delivered by an AHPRA-registered physiotherapist. Targeted, evidence-based, and tied directly to your rehabilitation goals — not group fitness with a label.</p>
            <span class="mt-4 inline-flex items-center gap-1.5 font-semibold text-forest group-hover:gap-3 transition-all">Book a session <span aria-hidden="true">→</span></span>
          </div>
        </a>

        {[services[2], services[3], services[4], services[6]].map((s) => (
          <a href={`/services/${s.slug}`} class="group card card-hover md:col-span-2 p-7 flex flex-col reveal">
            <span class="w-12 h-12 rounded-2xl bg-sage/25 text-forest grid place-items-center mb-4 transition-colors group-hover:bg-sage/40">
              <ServiceIcon name={s.icon} />
            </span>
            <h3 class="font-display font-bold text-xl text-forest">{s.title}</h3>
            <p class="mt-2 text-sm text-charcoal/70 flex-1">{s.short}</p>
            <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-forest group-hover:gap-3 transition-all">Learn more <span aria-hidden="true">→</span></span>
          </a>
        ))}

        <a href="/services" class="group card card-hover md:col-span-4 p-7 flex flex-col sm:flex-row sm:items-center justify-between gap-4 reveal !bg-forest">
          <p class="text-cream/90"><span class="font-display font-bold text-cream">Also offering:</span> Remedial Massage with Alan, Podiatry, Hydrotherapy, Workers Comp + MVA claims.</p>
          <span class="inline-flex items-center gap-1.5 font-semibold text-sage group-hover:gap-3 transition-all whitespace-nowrap">See all services <span aria-hidden="true">→</span></span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============ 6. DARK STATS ============ -->
  <section class="relative bg-night overflow-hidden">
    <div class="absolute inset-0 grain opacity-[0.05]" aria-hidden="true"></div>
    <div class="container-page section relative">
      <div class="max-w-2xl mb-12 reveal">
        <p class="eyebrow text-sage mb-3">By the numbers</p>
        <h2 class="font-display font-extrabold text-cream text-4xl md:text-5xl">8 years. 10+ years experience. <span class="accent">81 five-star reviews.</span></h2>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-5">
        {stats.map((s) => (
          <div class="rounded-3xl border border-sage/30 bg-sage/5 p-7 text-center reveal" style="box-shadow:0 0 40px -20px rgba(156,192,132,0.5)">
            <p class="font-display font-extrabold text-sage text-5xl md:text-6xl tnum" data-counter={String(s.value)} data-suffix={s.suffix} data-decimal={String(!!s.decimal)}>0{s.suffix}</p>
            <p class="mt-3 text-sm text-cream/70 leading-snug">{s.label}</p>
          </div>
        ))}
      </div>
      <p class="mt-10 text-cream/70 max-w-2xl reveal">
        Every initial assessment is conducted by Vincent personally. No one else builds
        your plan. No call centres. No bouncing between locums.
      </p>
    </div>
  </section>

  <!-- ============ 7. FOUNDER STORY ============ -->
  <section class="bg-cream section">
    <div class="container-page grid lg:grid-cols-12 gap-10 lg:gap-16 items-center">
      <div class="lg:col-span-5 reveal">
        <div class="relative">
          <div class="absolute -inset-3 bg-forest/10 rounded-[2.5rem] rotate-2" aria-hidden="true"></div>
          <img src={vincent.image} alt={vincent.imageAlt} width="700" height="875" loading="lazy" class="relative rounded-[2rem] object-cover aspect-[4/5] w-full bg-ivory shadow-xl"/>
        </div>
      </div>
      <div class="lg:col-span-7">
        <p class="eyebrow text-forest mb-3 reveal">About the founder</p>
        <h2 class="font-display font-extrabold text-forest text-4xl md:text-5xl reveal">Meet Vincent.</h2>
        <p class="mt-2 font-display italic text-warmgrey text-lg reveal">Senior Physiotherapist + Founder · BSc Physiotherapy (Curtin)</p>
        <div class="mt-6 space-y-4 text-charcoal/80 leading-relaxed reveal">
          <p class="first-letter:font-display first-letter:text-5xl first-letter:font-extrabold first-letter:text-forest first-letter:float-left first-letter:mr-2 first-letter:leading-[0.8]">{vincent.bio[0]}</p>
          <p>{vincent.bio[1]}</p>
        </div>
        <div class="mt-6 flex flex-wrap gap-2 reveal">
          {vincent.credentials?.map((c) => <span class="chip">{c}</span>)}
        </div>
        <div class="mt-8 flex flex-col sm:flex-row gap-3 reveal">
          <a href="/about/team" class="btn btn-outline">Meet the full team</a>
          <a href={site.booking} target="_blank" rel="noopener" class="btn btn-primary" data-magnetic data-ripple>Book with Vincent</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ 8. TEAM PREVIEW ============ -->
  <section class="bg-ivory section">
    <div class="container-page">
      <div class="flex flex-wrap items-end justify-between gap-4 mb-10">
        <div class="reveal">
          <p class="eyebrow text-forest mb-3">Our team</p>
          <h2 class="font-display font-extrabold text-forest text-4xl md:text-5xl">Small clinic. <span class="accent">Right people.</span></h2>
        </div>
        <a href="/about/team" class="btn btn-outline reveal">Meet the team</a>
      </div>
      <div class="grid sm:grid-cols-3 gap-6">
        {team.map((m) => (
          <div class="card card-hover overflow-hidden flex flex-col reveal">
            <div class="aspect-[4/5] bg-ivory overflow-hidden">
              {m.image ? (
                <img src={m.image} alt={m.imageAlt} width="500" height="625" loading="lazy" class="w-full h-full object-cover"/>
              ) : (
                <div class="w-full h-full grid place-items-center text-forest/30 bg-forest/5">
                  <span class="font-display text-6xl">{m.name.split(' ').map((n) => n[0]).join('')}</span>
                </div>
              )}
            </div>
            <div class="p-6 flex-1 flex flex-col">
              <h3 class="font-display font-bold text-xl text-forest">{m.name}</h3>
              <p class="text-sm text-sage font-semibold">{m.role}</p>
              <p class="mt-2 text-sm text-charcoal/70 flex-1">{m.short}</p>
              {m.placeholder && <p class="mt-2 text-xs text-orange">Availability to be confirmed</p>}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ 9. PROCESS ============ -->
  <section class="bg-cream section">
    <div class="container-page">
      <div class="max-w-2xl mb-12 reveal">
        <p class="eyebrow text-forest mb-3">What to expect</p>
        <h2 class="font-display font-extrabold text-forest text-4xl md:text-5xl">From <span class="accent">first call to recovery</span>, in four steps.</h2>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {processSteps.map((step) => (
          <div class="card card-hover p-7 reveal">
            <p class="font-display font-extrabold text-sage text-6xl leading-none tnum">{step.n}</p>
            <h3 class="mt-4 font-display font-bold text-xl text-forest">{step.title}</h3>
            <p class="mt-2 text-sm text-charcoal/70">{step.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ 10. CONDITIONS ============ -->
  <section class="bg-ivory section">
    <div class="container-page">
      <div class="max-w-2xl mb-10 reveal">
        <p class="eyebrow text-forest mb-3">Common conditions</p>
        <h2 class="font-display font-extrabold text-forest text-4xl md:text-5xl">Treatment for what's <span class="accent">actually causing your pain.</span></h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {conditions.map((c) => (
          <a href={`/conditions/${c.slug}`} class="group card card-hover p-6 flex items-center justify-between gap-3 reveal">
            <div>
              <h3 class="font-display font-bold text-lg text-forest">{c.name}</h3>
              <p class="text-sm text-charcoal/65 mt-0.5">{c.short}</p>
            </div>
            <span class="text-sage text-xl group-hover:translate-x-1 transition-transform" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
      <div class="mt-8 reveal"><a href="/conditions" class="btn btn-outline">See all conditions we treat</a></div>
    </div>
  </section>

  <!-- ============ 11. REFORMER FEATURE ============ -->
  <section class="relative bg-forest overflow-hidden section">
    <div class="absolute inset-0 opacity-[0.12]" aria-hidden="true">
      <img src="/photos/services/reformer-pilates.jpg" alt="" width="1400" height="600" loading="lazy" class="w-full h-full object-cover"/>
    </div>
    <div class="container-page relative grid lg:grid-cols-2 gap-10 items-center">
      <div class="text-cream reveal">
        <p class="eyebrow text-sage mb-3">Our differentiator</p>
        <h2 class="font-display font-extrabold text-4xl md:text-5xl">Reformer Pilates with an <span class="accent">actual physiotherapist.</span></h2>
        <p class="mt-6 text-cream/80 leading-relaxed">
          Most reformer pilates studios are fitness studios. We're a physiotherapy clinic
          that uses reformer pilates clinically — delivered one-on-one by an
          AHPRA-registered physiotherapist, prescribed specifically for your
          rehabilitation goals.
        </p>
        <ul class="mt-6 grid sm:grid-cols-2 gap-2 text-cream/85 text-sm">
          {['Post-surgical rehabilitation', 'Chronic lower back pain', 'Sports performance', 'Pelvic floor strengthening', 'Pre-natal & post-natal recovery', 'Strength under expert supervision'].map((i) => (
            <li class="flex items-center gap-2"><span class="text-sage">✓</span>{i}</li>
          ))}
        </ul>
        <a href="/services/reformer-pilates" class="btn btn-sage mt-8" data-magnetic data-ripple>Book a clinical reformer session</a>
      </div>
      <div class="reveal hidden lg:block">
        <img src="/photos/services/reformer-pilates.jpg" alt="Clinical reformer pilates studio" width="700" height="520" loading="lazy" class="rounded-3xl shadow-2xl object-cover w-full aspect-[4/3] -rotate-1"/>
      </div>
    </div>
  </section>

  <!-- ============ 12. INSURANCE ============ -->
  <section class="bg-ivory section">
    <div class="container-page">
      <div class="max-w-2xl mb-10 reveal">
        <p class="eyebrow text-forest mb-3">Rebates + claims</p>
        <h2 class="font-display font-extrabold text-forest text-4xl md:text-5xl">Claim back. <span class="accent">Or don't pay upfront.</span></h2>
      </div>
      <div class="grid md:grid-cols-3 gap-5">
        {[
          { t: 'Private Health', b: 'NIB Preferred Provider with HICAPS terminal — claim back instantly. We also process HBF, Medibank, Bupa, HCF and Westfund.', href: '/services/insurance-claims', icon: 'shield' },
          { t: 'Workers Compensation', b: 'WorkCover WA claims handled, paperwork included. You focus on recovery and return to work.', href: '/services/workers-compensation', icon: 'recovery' },
          { t: 'Motor Vehicle', b: 'ICWA / CTP claims handled, with a clear post-accident rehabilitation pathway.', href: '/services/motor-vehicle-claims', icon: 'physio' },
        ].map((c) => (
          <a href={c.href} class="group card card-hover p-7 reveal">
            <span class="w-12 h-12 rounded-2xl bg-sage/25 text-forest grid place-items-center mb-4"><ServiceIcon name={c.icon}/></span>
            <h3 class="font-display font-bold text-xl text-forest">{c.t}</h3>
            <p class="mt-2 text-sm text-charcoal/70">{c.b}</p>
            <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-forest group-hover:gap-3 transition-all">Learn more <span aria-hidden="true">→</span></span>
          </a>
        ))}
      </div>
      <p class="mt-6 text-sm text-warmgrey reveal">
        NDIS participants and DVA cardholders are also welcome — see our
        <a href="/ndis" class="text-forest font-semibold underline underline-offset-2">NDIS</a> and
        <a href="/dva" class="text-forest font-semibold underline underline-offset-2">DVA</a> pages.
      </p>
    </div>
  </section>

  <!-- ============ 13. MARQUEE ============ -->
  <Marquee items={marqueeItems} />

  <!-- ============ 14. REVIEWS ============ -->
  <section class="bg-cream section">
    <div class="container-page">
      <div class="max-w-2xl mb-10 reveal">
        <p class="eyebrow text-forest mb-3">What patients say</p>
        <h2 class="font-display font-extrabold text-forest text-4xl md:text-5xl">5.0 ★ from <span class="accent">81 Google reviews.</span></h2>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5 items-start">
        <ReviewCard review={reviews[3]} class="lg:row-span-2" />
        <ReviewCard review={reviews[0]} />
        <ReviewCard review={reviews[1]} />
        <ReviewCard review={reviews[2]} class="md:col-span-2 lg:col-span-1" />
        <ReviewCard review={reviews[4]} />
      </div>
      <div class="mt-8 flex flex-col sm:flex-row items-start sm:items-center gap-4 justify-between reveal">
        <a href="/reviews" class="btn btn-primary" data-magnetic data-ripple>Read all 81 reviews</a>
        <p class="text-xs text-warmgrey max-w-md">{reviewDisclaimer}</p>
      </div>
    </div>
  </section>

  <!-- ============ 16. CONTACT PREVIEW ============ -->
  <section class="bg-ivory section">
    <div class="container-page grid lg:grid-cols-2 gap-10">
      <div class="reveal">
        <p class="eyebrow text-forest mb-3">Visit the clinic</p>
        <h2 class="font-display font-extrabold text-forest text-4xl md:text-5xl">West Perth, <span class="accent">on Newcastle St.</span></h2>
        <dl class="mt-8 space-y-5 text-charcoal/80">
          <div>
            <dt class="eyebrow text-forest/60 mb-1">Address</dt>
            <dd>{site.address.full}</dd>
          </div>
          <div>
            <dt class="eyebrow text-forest/60 mb-1">Phone</dt>
            <dd><a class="hover:text-forest font-semibold" href={`tel:${site.phoneHref}`}>{site.phoneDisplay}</a></dd>
          </div>
          <div>
            <dt class="eyebrow text-forest/60 mb-2">Opening hours</dt>
            <dd>
              <ul class="space-y-1 text-sm">
                {site.hours.map((h) => (
                  <li class="flex justify-between max-w-xs"><span>{h.day}</span><span class={h.open ? 'text-charcoal/80 tnum' : 'text-warmgrey'}>{h.time}</span></li>
                ))}
              </ul>
            </dd>
          </div>
        </dl>
        <a href="/contact" class="btn btn-outline mt-8">Get directions & contact</a>
      </div>
      <div class="reveal rounded-3xl overflow-hidden shadow-xl border border-forest/10 min-h-[360px]">
        <iframe
          title="PhysioLogix location map"
          src={`https://www.google.com/maps?q=${site.address.mapsQuery}&output=embed`}
          class="w-full h-full min-h-[360px]"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>
  </section>
</Layout>
