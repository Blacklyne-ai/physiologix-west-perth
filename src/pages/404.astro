---
import Layout from '../layouts/Layout.astro';
import { site } from '../data/site';
---
<Layout title="Page not found" description="The page you're looking for has moved or doesn't exist." path="/404" noindex={true}>
  <section class="bg-ivory min-h-[70vh] grid place-items-center pt-32 pb-20">
    <div class="container-page text-center max-w-xl">
      <p class="font-display font-extrabold text-sage text-[8rem] leading-none tnum">404</p>
      <h1 class="font-display font-extrabold text-forest text-3xl md:text-4xl mt-2">This one got away from us.</h1>
      <p class="mt-4 text-charcoal/75">The page you're after has moved or no longer exists. Let's get you back on track — a bit like we do best.</p>
      <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/" class="btn btn-primary" data-magnetic data-ripple>Back to home</a>
        <a href={site.booking} target="_blank" rel="noopener" class="btn btn-outline">Book online</a>
      </div>
      <div class="mt-8 flex flex-wrap gap-2 justify-center">
        <a href="/services" class="chip hover:bg-sage/40 transition-colors">Services</a>
        <a href="/conditions" class="chip hover:bg-sage/40 transition-colors">Conditions</a>
        <a href="/about" class="chip hover:bg-sage/40 transition-colors">About</a>
        <a href="/contact" class="chip hover:bg-sage/40 transition-colors">Contact</a>
      </div>
    </div>
  </section>
</Layout>
