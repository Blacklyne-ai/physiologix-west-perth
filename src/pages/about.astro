---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import CTABand from '../components/CTABand.astro';
import { team, site, processSteps } from '../data/site';
const vincent = team[0];
---

<Layout
  title="About"
  description="PhysioLogix is a founder-led physiotherapy and pilates clinic in West Perth, established 2017 by Vincent Harvey. Diagnostic-first care, deliberately small."
  path="/about"
>
  <PageHero
    eyebrow="About PhysioLogix"
    title="A clinic built around"
    accent="the diagnosis."
    lead="PhysioLogix opened in 2017 with one intent: to elevate the standard of physiotherapy in West Perth. We stay deliberately small so the care stays personal."
    crumbs={[{ label: 'About' }]}
  />

  <section class="bg-ivory section">
    <div class="container-page grid lg:grid-cols-12 gap-10 lg:gap-16 items-center">
      <div class="lg:col-span-5 reveal">
        <div class="relative">
          <div class="absolute -inset-3 bg-forest/10 rounded-[2.5rem] -rotate-2" aria-hidden="true"></div>
          <img src={vincent.image} alt={vincent.imageAlt} width="700" height="875" loading="lazy" class="relative rounded-[2rem] object-cover aspect-[4/5] w-full bg-ivory shadow-xl"/>
        </div>
      </div>
      <div class="lg:col-span-7">
        <p class="eyebrow text-forest mb-3 reveal">Our founder</p>
        <h2 class="font-display font-extrabold text-forest text-3xl md:text-4xl reveal">Founded and led by Vincent Harvey.</h2>
        <div class="mt-6 space-y-4 text-charcoal/80 leading-relaxed reveal">
          {vincent.bio.map((p) => <p>{p}</p>)}
        </div>
        <div class="mt-6 flex flex-wrap gap-2 reveal">
          {vincent.credentials?.map((c) => <span class="chip">{c}</span>)}
        </div>
        <a href="/about/team" class="btn btn-outline mt-8 reveal">Meet the full team</a>
      </div>
    </div>
  </section>

  <section class="bg-cream section">
    <div class="container-page">
      <div class="max-w-2xl mb-10 reveal">
        <p class="eyebrow text-forest mb-3">How we work</p>
        <h2 class="font-display font-extrabold text-forest text-3xl md:text-4xl">Diagnostic-first, <span class="accent">always.</span></h2>
        <p class="mt-4 text-charcoal/75">We don't run on volume. Vincent personally conducts every initial assessment, treatment plans are built individually, and you'll always understand what you're doing and why.</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {processSteps.map((step) => (
          <div class="card card-hover p-7 reveal">
            <p class="font-display font-extrabold text-sage text-5xl leading-none tnum">{step.n}</p>
            <h3 class="mt-3 font-display font-bold text-lg text-forest">{step.title}</h3>
            <p class="mt-2 text-sm text-charcoal/70">{step.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-ivory section">
    <div class="container-page grid lg:grid-cols-2 gap-10 items-center">
      <div class="reveal">
        <p class="eyebrow text-forest mb-3">The clinic</p>
        <h2 class="font-display font-extrabold text-forest text-3xl md:text-4xl">In the heart of <span class="accent">West Perth.</span></h2>
        <p class="mt-5 text-charcoal/80 leading-relaxed">You'll find us at {site.address.full}, on the Newcastle Street artery between West Perth and Northbridge — convenient for professionals across Perth's inner city, Leederville, Subiaco and beyond.</p>
        <p class="mt-4 text-charcoal/80 leading-relaxed">Booking is handled through Cliniko, so you can book online any time, get a confirmation, and complete your pre-appointment form before you arrive.</p>
        <div class="mt-7 flex flex-col sm:flex-row gap-3">
          <a href={site.booking} target="_blank" rel="noopener" class="btn btn-primary" data-magnetic data-ripple>Book online</a>
          <a href="/contact" class="btn btn-outline">Find us</a>
        </div>
      </div>
      <div class="reveal">
        <img src="/photos/clinic/clinic-interior-1.jpg" alt="Inside the PhysioLogix clinic in West Perth" width="800" height="600" loading="lazy" class="rounded-3xl shadow-xl object-cover w-full aspect-[4/3]"/>
      </div>
    </div>
  </section>

  <CTABand heading="Come and see the" accent="difference." />
</Layout>
