---
import AudiencePage from '../../components/AudiencePage.astro';
---
<AudiencePage
  seoTitle="Workers Compensation Physiotherapy"
  description="WorkCover WA physiotherapy in West Perth. We handle the paperwork and build return-to-work programmes so you can focus on recovery."
  path="/services/workers-compensation"
  eyebrow="WorkCover WA"
  title="Hurt at work?"
  accent="We've got the paperwork."
  lead="We treat Workers Compensation claims under WorkCover WA — and we handle the administration so you can put your energy into recovering and getting back to work."
  crumbs={[{ label: 'Services', href: '/services' }, { label: 'Workers Compensation' }]}
  intro={[
    "A workplace injury is stressful enough without a mountain of forms. We treat WorkCover WA claims and manage the paperwork side — progress reports, certificates and liaison with your case — so the process stays as smooth as possible.",
    "Treatment follows the same diagnostic-first approach as the rest of the clinic: find the real cause, build an individual plan, and progress you safely toward a return to work and the activities you value.",
  ]}
  checklistHeading="What we handle"
  checklist={[
    'Treatment under approved WorkCover WA claims',
    'Progress reporting and certificates',
    'Liaison with your treating GP and case manager',
    'Structured return-to-work programmes',
    'Direct billing where available',
  ]}
  highlights={[
    { t: 'Return-to-work focus', d: 'Graded programmes designed around the demands of your actual job.', icon: 'recovery' },
    { t: 'Paperwork managed', d: 'We take care of the reporting so you can focus on getting better.', icon: 'shield' },
    { t: 'One clinician', d: 'Vincent personally manages your assessment and plan — no bouncing around.', icon: 'physio' },
  ]}
  ctaHeading="Start your"
  ctaAccent="recovery."
  ctaSub="Call us with your claim details and we'll talk you through the next steps."
  primaryCtaLabel="Book an assessment"
/>
