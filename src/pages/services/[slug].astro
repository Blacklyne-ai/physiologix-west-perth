---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import CTABand from '../../components/CTABand.astro';
import ServiceIcon from '../../components/ServiceIcon.astro';
import { services, conditions, site } from '../../data/site';

export function getStaticPaths() {
  return services.map((s) => ({ params: { slug: s.slug }, props: { service: s } }));
}

const { service } = Astro.props;
const related = conditions.filter((c) => c.related.includes(service.slug)).slice(0, 4);
const others = services.filter((s) => s.slug !== service.slug).slice(0, 3);

const schema = {
  '@context': 'https://schema.org',
  '@type': 'MedicalProcedure',
  name: service.title,
  description: service.intro,
  url: new URL(`/services/${service.slug}`, Astro.site).href,
  provider: { '@type': 'MedicalBusiness', name: site.legalName },
};
---

<Layout
  title={`${service.title} West Perth`}
  description={service.intro}
  path={`/services/${service.slug}`}
  schema={schema}
>
  <PageHero
    eyebrow={service.eyebrow}
    title={service.title}
    lead={service.intro}
    crumbs={[{ label: 'Services', href: '/services' }, { label: service.title }]}
  >
    <div class="mt-8 flex flex-col sm:flex-row gap-3 reveal">
      <a href={site.booking} target="_blank" rel="noopener" class="btn btn-primary" data-magnetic data-ripple>Book online</a>
      <a href={`tel:${site.phoneHref}`} class="btn btn-outline">Call {site.phoneDisplay}</a>
    </div>
  </PageHero>

  <section class="bg-ivory section">
    <div class="container-page grid lg:grid-cols-12 gap-10 lg:gap-16">
      <div class="lg:col-span-7">
        <div class="prose-plx space-y-5 text-lg text-charcoal/80 leading-relaxed">
          {service.body.map((p) => <p class="reveal">{p}</p>)}
        </div>

        {service.image && (
          <img src={service.image} alt={service.imageAlt} width="900" height="600" loading="lazy" class="mt-8 rounded-3xl shadow-xl object-cover w-full aspect-[3/2] reveal"/>
        )}
      </div>

      <aside class="lg:col-span-5">
        <div class="card p-7 sticky top-28 reveal">
          <span class="w-12 h-12 rounded-2xl bg-sage/25 text-forest grid place-items-center mb-4"><ServiceIcon name={service.icon}/></span>
          <h2 class="font-display font-bold text-xl text-forest">What's involved</h2>
          <ul class="mt-4 space-y-2.5">
            {service.bullets.map((b) => (
              <li class="flex items-start gap-2.5 text-charcoal/80">
                <span class="text-sage mt-1 shrink-0" aria-hidden="true">✓</span><span>{b}</span>
              </li>
            ))}
          </ul>
          <a href={site.booking} target="_blank" rel="noopener" class="btn btn-primary w-full mt-6" data-ripple>Book this service</a>
          <p class="mt-4 text-xs text-warmgrey">Not sure if this is right for you? Call {site.phoneDisplay} and we'll point you in the right direction.</p>
        </div>
      </aside>
    </div>
  </section>

  {related.length > 0 && (
    <section class="bg-cream section-tight">
      <div class="container-page">
        <h2 class="font-display font-bold text-2xl md:text-3xl text-forest mb-6 reveal">Conditions we often treat with this</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
          {related.map((c) => (
            <a href={`/conditions/${c.slug}`} class="group card card-hover p-5 reveal">
              <h3 class="font-display font-bold text-forest">{c.name}</h3>
              <span class="mt-2 inline-flex items-center gap-1 text-sm font-semibold text-forest group-hover:gap-2.5 transition-all">Learn more <span aria-hidden="true">→</span></span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="bg-ivory section-tight">
    <div class="container-page">
      <h2 class="font-display font-bold text-2xl md:text-3xl text-forest mb-6 reveal">Other services</h2>
      <div class="grid sm:grid-cols-3 gap-4">
        {others.map((s) => (
          <a href={`/services/${s.slug}`} class="group card card-hover p-6 reveal">
            <span class="w-11 h-11 rounded-2xl bg-sage/25 text-forest grid place-items-center mb-3"><ServiceIcon name={s.icon} class="w-5 h-5"/></span>
            <h3 class="font-display font-bold text-forest">{s.title}</h3>
            <p class="text-sm text-charcoal/65 mt-1">{s.short}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTABand heading="Book your" accent="assessment." />
</Layout>
