---
import AudiencePage from '../../components/AudiencePage.astro';
---
<AudiencePage
  seoTitle="Motor Vehicle Claim Physiotherapy"
  description="Physiotherapy for motor vehicle accident injuries in West Perth. ICWA / CTP claims handled, with whiplash and post-accident rehabilitation."
  path="/services/motor-vehicle-claims"
  eyebrow="ICWA / CTP claims"
  title="After an accident,"
  accent="we'll help you recover."
  lead="We treat injuries from motor vehicle accidents under ICWA (Insurance Commission of WA) and CTP claims — including whiplash and a clear post-accident rehabilitation pathway."
  crumbs={[{ label: 'Services', href: '/services' }, { label: 'Motor Vehicle Claims' }]}
  intro={[
    "Car accidents can leave lasting injuries — whiplash, neck and back pain, and the kind of niggles that don't show up until days later. We treat these injuries under your motor vehicle claim and guide you through structured rehabilitation.",
    "We work within the ICWA / CTP framework, keeping the necessary records and reporting in order while you focus on getting back to normal life.",
  ]}
  checklistHeading="What we handle"
  checklist={[
    'Treatment under ICWA / CTP claims',
    'Whiplash and neck injury rehabilitation',
    'Post-accident exercise programmes',
    'Records and reporting for your claim',
    'Coordination with your GP',
  ]}
  highlights={[
    { t: 'Whiplash expertise', d: 'A common motor vehicle injury — assessed and treated thoroughly.', icon: 'physio' },
    { t: 'Claim records kept', d: 'We keep the documentation your claim requires.', icon: 'shield' },
    { t: 'Clear pathway', d: 'A staged rehabilitation plan from acute injury back to full function.', icon: 'recovery' },
  ]}
  ctaHeading="Recover after your"
  ctaAccent="accident."
  ctaSub="Call us with your claim details and we'll explain how treatment works."
  primaryCtaLabel="Book an assessment"
/>
