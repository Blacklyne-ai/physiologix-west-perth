---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import CTABand from '../../components/CTABand.astro';
import { team, site } from '../../data/site';
---

<Layout
  title="Our Team"
  description="Meet the PhysioLogix team — Vincent Harvey (Senior Physiotherapist + Founder), Alan Mahmood (Remedial Masseuse) and our podiatry care."
  path="/about/team"
>
  <PageHero
    eyebrow="Our team"
    title="Small clinic."
    accent="Right people."
    lead="A deliberately small team means consistent, personal care. The person who assesses you is the person who treats you."
    crumbs={[{ label: 'About', href: '/about' }, { label: 'Team' }]}
  />

  <section class="bg-ivory section">
    <div class="container-page space-y-16">
      {team.map((m, i) => (
        <div class={`grid lg:grid-cols-12 gap-8 lg:gap-14 items-center ${i % 2 === 1 ? 'lg:[&>*:first-child]:order-2' : ''}`}>
          <div class="lg:col-span-5 reveal">
            <div class="relative">
              <div class={`absolute -inset-3 bg-sage/15 rounded-[2.5rem] ${i % 2 === 0 ? 'rotate-2' : '-rotate-2'}`} aria-hidden="true"></div>
              {m.image ? (
                <img src={m.image} alt={m.imageAlt} width="700" height="875" loading="lazy" class="relative rounded-[2rem] object-cover aspect-[4/5] w-full bg-ivory shadow-xl"/>
              ) : (
                <div class="relative rounded-[2rem] aspect-[4/5] w-full bg-forest/5 grid place-items-center shadow-xl">
                  <span class="font-display text-7xl text-forest/30">{m.name.split(' ').map((n) => n[0]).join('')}</span>
                </div>
              )}
            </div>
          </div>
          <div class="lg:col-span-7">
            <h2 class="font-display font-extrabold text-forest text-3xl md:text-4xl reveal">{m.name}</h2>
            <p class="mt-1 text-sage font-semibold reveal">{m.role}</p>
            {m.placeholder && <p class="mt-2 text-sm text-orange reveal">Availability to be confirmed — please ask when booking.</p>}
            <div class="mt-5 space-y-4 text-charcoal/80 leading-relaxed reveal">
              {m.bio.map((p) => <p>{p}</p>)}
            </div>
            {m.credentials && (
              <div class="mt-6 flex flex-wrap gap-2 reveal">
                {m.credentials.map((c) => <span class="chip">{c}</span>)}
              </div>
            )}
            <a href={site.booking} target="_blank" rel="noopener" class="btn btn-primary mt-7 reveal" data-magnetic data-ripple>Book with {m.name.split(' ')[0]}</a>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="bg-cream section-tight">
    <div class="container-page text-center max-w-2xl mx-auto reveal">
      <h2 class="font-display font-bold text-2xl md:text-3xl text-forest">Want to join the team?</h2>
      <p class="mt-3 text-charcoal/75">We're always interested in hearing from physiotherapists and allied health professionals who share our standard of care.</p>
      <a href="/careers" class="btn btn-outline mt-6">See careers</a>
    </div>
  </section>

  <CTABand heading="Book with the" accent="right person." />
</Layout>
