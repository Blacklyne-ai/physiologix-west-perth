---
import { site } from '../data/site';
---
<div
  class="fixed bottom-5 right-5 z-40 flex flex-col gap-3 opacity-0 translate-y-4 pointer-events-none transition-all duration-500"
  data-floating-cta
>
  <a
    href={site.booking}
    target="_blank"
    rel="noopener"
    class="group flex items-center gap-2 rounded-full bg-forest text-cream pl-4 pr-5 py-3.5 shadow-xl hover:shadow-2xl transition-shadow"
    aria-label="Book online via Cliniko"
    data-ripple
  >
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><rect x="3" y="4.5" width="18" height="16" rx="2"/><path d="M3 9h18M8 2.5v4M16 2.5v4"/></svg>
    <span class="text-sm font-semibold">Book online</span>
  </a>
  <a
    href={`tel:${site.phoneHref}`}
    class="flex items-center justify-center w-14 h-14 ml-auto rounded-full bg-sage text-night shadow-xl hover:shadow-2xl transition-shadow"
    aria-label={`Call ${site.phoneDisplay}`}
  >
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.9v3a2 2 0 01-2.2 2 19.8 19.8 0 01-8.6-3.1 19.5 19.5 0 01-6-6 19.8 19.8 0 01-3.1-8.7A2 2 0 014.1 2h3a2 2 0 012 1.7c.1.9.3 1.8.6 2.7a2 2 0 01-.5 2.1L8 9.6a16 16 0 006 6l1.1-1.1a2 2 0 012.1-.5c.9.3 1.8.5 2.7.6a2 2 0 011.7 2z"/></svg>
  </a>
</div>

<script>
  const cta = document.querySelector('[data-floating-cta]');
  const onScroll = () => {
    if (window.scrollY > 200) cta?.classList.remove('opacity-0', 'translate-y-4', 'pointer-events-none');
    else cta?.classList.add('opacity-0', 'translate-y-4', 'pointer-events-none');
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });
</script>
