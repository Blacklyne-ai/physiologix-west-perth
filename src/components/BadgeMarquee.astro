---
// Moving marquee of trust badges — image badges sit in white cards,
// text badges as styled pills. Pauses on hover, respects reduced-motion.
import { site } from '../data/site';

type Badge =
  | { type: 'img'; src: string; alt: string }
  | { type: 'stars'; label: string }
  | { type: 'text'; label: string };

const badges: Badge[] = [
  { type: 'img', src: '/photos/badges/nib-preferred-provider.jpg', alt: 'NIB First Choice preferred provider' },
  { type: 'stars', label: `5.0 · ${site.reviewCount} Google reviews` },
  { type: 'text', label: 'AHPRA Registered' },
  { type: 'text', label: 'HICAPS Available' },
  { type: 'text', label: 'HBF' },
  { type: 'text', label: 'Medibank' },
  { type: 'text', label: 'Bupa' },
  { type: 'text', label: 'HCF' },
  { type: 'text', label: 'Westfund' },
  { type: 'text', label: 'WorkCover WA' },
  { type: 'text', label: 'ICWA / Motor Vehicle' },
  { type: 'text', label: 'NDIS & DVA Welcome' },
];
const loop = [...badges, ...badges];
---

<section class="bg-cream border-y border-forest/10 py-6" aria-label="Accreditations and accepted insurers">
  <h2 class="sr-only">Accreditations and accepted insurers</h2>
  <div class="marquee overflow-hidden">
    <div class="marquee-track items-center gap-4">
      {loop.map((b) => (
        <div class="shrink-0">
          {b.type === 'img' && (
            <div class="h-14 px-6 rounded-2xl bg-white shadow-sm border border-forest/5 grid place-items-center">
              <img src={b.src} alt={b.alt} height="32" class="h-8 w-auto object-contain" loading="lazy" />
            </div>
          )}
          {b.type === 'stars' && (
            <div class="h-14 px-6 rounded-2xl bg-forest text-cream shadow-sm grid place-items-center">
              <span class="flex items-center gap-2 whitespace-nowrap font-semibold">
                <span class="flex text-sage" aria-hidden="true">
                  {Array.from({ length: 5 }).map(() => (<svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3 6.5 7 .9-5.2 4.8 1.4 7-6.2-3.6L6 21.2l1.4-7L2.2 9.4l7-.9z"/></svg>))}
                </span>
                <span class="tnum text-sm">{b.label}</span>
              </span>
            </div>
          )}
          {b.type === 'text' && (
            <div class="h-14 px-6 rounded-2xl bg-ivory border border-forest/10 grid place-items-center">
              <span class="flex items-center gap-2 whitespace-nowrap font-semibold text-forest">
                <span class="text-sage" aria-hidden="true">✓</span>{b.label}
              </span>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
