---
import type { Review } from '../data/site';
interface Props { review: Review; class?: string; }
const { review, class: cls = '' } = Astro.props;
---
<figure class={`card card-hover p-7 flex flex-col reveal ${cls}`} data-tilt>
  <div class="flex items-center gap-1 text-sage mb-4" aria-label="5 out of 5 stars">
    {Array.from({ length: 5 }).map(() => (
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3 6.5 7 .9-5.2 4.8 1.4 7-6.2-3.6L6 21.2l1.4-7L2.2 9.4l7-.9z"/></svg>
    ))}
  </div>
  <blockquote class="text-charcoal/85 leading-relaxed flex-1">{review.text}</blockquote>
  <figcaption class="mt-5 flex items-center justify-between text-sm">
    <span class="font-semibold text-forest">{review.author}</span>
    {review.context && <span class="chip">{review.context}</span>}
  </figcaption>
</figure>
