---
// Custom hand-built line illustrations per service (NOT generic icon-set glyphs).
// Stroke uses currentColor so they adapt to context.
interface Props { name: string; class?: string; }
const { name, class: cls = 'w-7 h-7' } = Astro.props;
const s = { fill: 'none', stroke: 'currentColor', 'stroke-width': '1.6', 'stroke-linecap': 'round', 'stroke-linejoin': 'round' } as const;
---

{name === 'physio' && (
  <svg viewBox="0 0 32 32" class={cls} {...s} role="img" aria-hidden="true">
    <path d="M9 6c0 2 1.5 3.5 3.5 3.5S16 8 16 6" />
    <circle cx="12.5" cy="4" r="1.5" />
    <path d="M16 6c2.5 1 5 2 7 4.5" />
    <path d="M9 10c-1 4-1 8 0 12l-1.5 4" />
    <path d="M12.5 9.5c1 5 1 9 0 13l1.5 4" />
    <path d="M23 10.5c-2 1-4 1.5-6.5 1" />
  </svg>
)}
{name === 'pilates' && (
  <svg viewBox="0 0 32 32" class={cls} {...s} role="img" aria-hidden="true">
    <rect x="4" y="13" width="24" height="6" rx="2" />
    <path d="M7 19v4M25 19v4M4 22h6M22 22h6" />
    <path d="M9 13l3-4M23 13l-3-4" />
    <circle cx="16" cy="9" r="1.4" />
  </svg>
)}
{name === 'needle' && (
  <svg viewBox="0 0 32 32" class={cls} {...s} role="img" aria-hidden="true">
    <path d="M6 26L20 12" />
    <path d="M20 12l4-4 2 2-4 4z" />
    <path d="M22 6l4 4" />
    <path d="M6 26l1.5-3.5L10 24z" />
  </svg>
)}
{name === 'hands' && (
  <svg viewBox="0 0 32 32" class={cls} {...s} role="img" aria-hidden="true">
    <path d="M11 20V9.5a1.5 1.5 0 013 0V18" />
    <path d="M14 18v-9a1.5 1.5 0 013 0v9" />
    <path d="M17 18v-7.5a1.5 1.5 0 013 0V19" />
    <path d="M20 14.5a1.5 1.5 0 013 0V21c0 3.5-2.5 6-6 6h-2c-2 0-3.5-1-4.5-3l-3-5a1.6 1.6 0 012.6-1.8L11 20" />
  </svg>
)}
{name === 'recovery' && (
  <svg viewBox="0 0 32 32" class={cls} {...s} role="img" aria-hidden="true">
    <path d="M16 26C8 21 4 16 4 11a5 5 0 019-3 5 5 0 019 3c0 2-.6 3.8-1.8 5.6" />
    <path d="M18 20h3l2-3 2 5h3" />
  </svg>
)}
{name === 'water' && (
  <svg viewBox="0 0 32 32" class={cls} {...s} role="img" aria-hidden="true">
    <path d="M16 4c4 5 7 9 7 13a7 7 0 01-14 0c0-4 3-8 7-13z" />
    <path d="M13 18c0 2 1.5 3.5 3.5 3.5" />
  </svg>
)}
{name === 'dumbbell' && (
  <svg viewBox="0 0 32 32" class={cls} {...s} role="img" aria-hidden="true">
    <path d="M12 16h8" />
    <rect x="5" y="12" width="4" height="8" rx="1" />
    <rect x="23" y="12" width="4" height="8" rx="1" />
    <path d="M9 14v4M23 14v4" />
  </svg>
)}
{name === 'massage' && (
  <svg viewBox="0 0 32 32" class={cls} {...s} role="img" aria-hidden="true">
    <path d="M4 22h24" />
    <path d="M6 22v-2a3 3 0 013-3h14a3 3 0 013 3v2" />
    <path d="M9 17c2-1.5 5-2.5 9-2.5" />
    <circle cx="22" cy="11" r="2" />
    <path d="M19 14c1-1 2.5-1.5 4-1" />
  </svg>
)}
{name === 'foot' && (
  <svg viewBox="0 0 32 32" class={cls} {...s} role="img" aria-hidden="true">
    <path d="M11 26c-1-3-1.5-6-1.5-9 0-5 2-9 5-9 2 0 3 1.5 3 4 0 2-1 3.5-1 5.5 0 2 1.5 3 4 3.5 2 .4 3.5 1.5 3.5 3.5 0 1.5-1 2.5-3 2.5z" />
    <circle cx="9" cy="9" r="1" /><circle cx="11.5" cy="7.5" r="1" /><circle cx="14" cy="7" r="1" />
  </svg>
)}
{name === 'shield' && (
  <svg viewBox="0 0 32 32" class={cls} {...s} role="img" aria-hidden="true">
    <path d="M16 4l10 4v6c0 7-4.5 11.5-10 14C10.5 25.5 6 21 6 14V8z" />
    <path d="M11.5 16l3 3 6-6" />
  </svg>
)}
{name === 'star' && (
  <svg viewBox="0 0 32 32" class={cls} {...s} role="img" aria-hidden="true">
    <path d="M16 5l3.2 6.6 7.3 1-5.3 5.1 1.3 7.2L16 21.6 9.2 25l1.3-7.2L5.2 12.6l7.3-1z" />
  </svg>
)}
{name === 'cap' && (
  <svg viewBox="0 0 32 32" class={cls} {...s} role="img" aria-hidden="true">
    <path d="M16 7l11 5-11 5L5 12z" />
    <path d="M10 14.5V19c0 1.5 2.7 3 6 3s6-1.5 6-3v-4.5" />
    <path d="M27 12v6" />
  </svg>
)}
