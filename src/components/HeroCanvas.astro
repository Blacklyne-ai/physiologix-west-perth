---
// Live WebGL flowing-gradient field — organic ivory/sage/forest, cursor-reactive.
// Degrades to the CSS aurora if WebGL is unavailable or reduced-motion is on.
---
<canvas
  data-hero-canvas
  class="absolute inset-0 w-full h-full opacity-0 transition-opacity duration-1000"
  aria-hidden="true"
  style="z-index:0"
></canvas>

<script>
  const canvas = document.querySelector<HTMLCanvasElement>('[data-hero-canvas]');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  // Desktop only — phones fall back to the lighter CSS aurora to save battery.
  const bigScreen = window.matchMedia('(min-width: 768px)').matches;
  if (canvas && !reduced && bigScreen) {
    const gl = canvas.getContext('webgl', { antialias: true, alpha: true, premultipliedAlpha: false });
    if (gl) {
      const vert = `
        attribute vec2 p;
        varying vec2 vUv;
        void main(){ vUv = p * 0.5 + 0.5; gl_Position = vec4(p, 0.0, 1.0); }`;
      const frag = `
        precision highp float;
        varying vec2 vUv;
        uniform float uTime;
        uniform vec2 uRes;
        uniform vec2 uMouse;
        float hash(vec2 p){ return fract(sin(dot(p, vec2(127.1,311.7)))*43758.5453); }
        float noise(vec2 p){
          vec2 i=floor(p), f=fract(p);
          float a=hash(i), b=hash(i+vec2(1.,0.)), c=hash(i+vec2(0.,1.)), d=hash(i+vec2(1.,1.));
          vec2 u=f*f*(3.-2.*f);
          return mix(mix(a,b,u.x), mix(c,d,u.x), u.y);
        }
        float fbm(vec2 p){ float v=0., a=.5; for(int i=0;i<5;i++){ v+=a*noise(p); p*=2.02; a*=.5; } return v; }
        void main(){
          vec2 uv = vUv;
          uv.x *= uRes.x / uRes.y;
          vec2 m = (uMouse - 0.5) * 0.45;
          float t = uTime * 0.045;
          vec2 q = vec2(fbm(uv*1.8 + t + m), fbm(uv*1.8 - t*0.8 + vec2(4.2,1.7) + m));
          float n = fbm(uv*2.4 + q*1.6 + t*0.6);
          vec3 ivory  = vec3(0.961,0.941,0.902);
          vec3 sage   = vec3(0.612,0.753,0.518);
          vec3 forest = vec3(0.165,0.239,0.200);
          vec3 col = mix(ivory, sage, smoothstep(0.38,0.82,n) * 0.5);
          col = mix(col, forest, smoothstep(0.72,0.98,n) * 0.07);
          // soft vignette toward ivory so text stays clean
          float vig = smoothstep(1.15, 0.2, length(vUv - vec2(0.32,0.5)));
          col = mix(ivory, col, 0.55 + vig*0.35);
          gl_FragColor = vec4(col, 1.0);
        }`;
      const compile = (type: number, src: string) => {
        const s = gl.createShader(type)!;
        gl.shaderSource(s, src); gl.compileShader(s);
        return gl.getShaderParameter(s, gl.COMPILE_STATUS) ? s : null;
      };
      const vs = compile(gl.VERTEX_SHADER, vert);
      const fs = compile(gl.FRAGMENT_SHADER, frag);
      if (vs && fs) {
        const prog = gl.createProgram()!;
        gl.attachShader(prog, vs); gl.attachShader(prog, fs); gl.linkProgram(prog);
        gl.useProgram(prog);
        const buf = gl.createBuffer();
        gl.bindBuffer(gl.ARRAY_BUFFER, buf);
        gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1,-1, 3,-1, -1,3]), gl.STATIC_DRAW);
        const loc = gl.getAttribLocation(prog, 'p');
        gl.enableVertexAttribArray(loc);
        gl.vertexAttribPointer(loc, 2, gl.FLOAT, false, 0, 0);
        const uTime = gl.getUniformLocation(prog, 'uTime');
        const uRes = gl.getUniformLocation(prog, 'uRes');
        const uMouse = gl.getUniformLocation(prog, 'uMouse');
        const mouse = { x: 0.5, y: 0.5 }, target = { x: 0.5, y: 0.5 };

        const resize = () => {
          const dpr = Math.min(window.devicePixelRatio || 1, 1.5);
          const w = canvas.clientWidth * dpr, h = canvas.clientHeight * dpr;
          if (canvas.width !== w || canvas.height !== h) {
            canvas.width = w; canvas.height = h;
            gl.viewport(0, 0, w, h);
          }
          gl.uniform2f(uRes, canvas.width, canvas.height);
        };
        const hero = canvas.closest('section');
        hero?.addEventListener('mousemove', (e) => {
          const r = hero.getBoundingClientRect();
          target.x = (e.clientX - r.left) / r.width;
          target.y = 1 - (e.clientY - r.top) / r.height;
        }, { passive: true });

        let running = true, start = performance.now();
        if ('IntersectionObserver' in window) {
          new IntersectionObserver((es) => { running = es[0].isIntersecting; if (running) loop(); },
            { threshold: 0 }).observe(canvas);
        }
        const loop = () => {
          if (!running) return;
          resize();
          mouse.x += (target.x - mouse.x) * 0.05;
          mouse.y += (target.y - mouse.y) * 0.05;
          gl.uniform1f(uTime, (performance.now() - start) / 1000);
          gl.uniform2f(uMouse, mouse.x, mouse.y);
          gl.drawArrays(gl.TRIANGLES, 0, 3);
          requestAnimationFrame(loop);
        };
        resize();
        canvas.style.opacity = '1';
        loop();
      }
    }
  }
</script>
