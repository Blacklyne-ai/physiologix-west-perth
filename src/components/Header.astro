---
import Logo from './Logo.astro';
import { site, nav } from '../data/site';
const path = Astro.url.pathname;
---

<header
  id="site-header"
  class="fixed top-0 inset-x-0 z-50 transition-all duration-300"
  data-header
>
  <div class="container-page">
    <div
      class="mt-3 flex items-center justify-between gap-4 rounded-full glass px-5 py-3 transition-all duration-300"
      data-header-bar
    >
      <Logo />

      <nav class="hidden lg:flex items-center gap-1" aria-label="Primary">
        {nav.map((item) => {
          const active = path === item.href || (item.href !== '/' && path.startsWith(item.href));
          return (
            <a
              href={item.href}
              class:list={[
                'relative px-3.5 py-2 text-sm font-semibold rounded-full transition-colors',
                active ? 'text-forest' : 'text-charcoal/70 hover:text-forest',
              ]}
              aria-current={active ? 'page' : undefined}
            >
              {item.label}
              <span class:list={['absolute left-3.5 right-3.5 -bottom-0.5 h-0.5 rounded-full bg-sage origin-left transition-transform duration-300', active ? 'scale-x-100' : 'scale-x-0']}></span>
            </a>
          );
        })}
      </nav>

      <div class="hidden md:flex items-center gap-2">
        <a href={`tel:${site.phoneHref}`} class="btn btn-outline !py-2.5 !px-4 text-sm">Call</a>
        <a href={site.booking} target="_blank" rel="noopener" class="btn btn-primary !py-2.5 !px-4 text-sm" data-magnetic data-ripple>Book online</a>
      </div>

      <button
        type="button"
        class="md:hidden inline-flex items-center justify-center w-10 h-10 rounded-full text-forest"
        aria-label="Open menu"
        aria-expanded="false"
        data-menu-toggle
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
      </button>
    </div>
  </div>

  <!-- Mobile drawer -->
  <div
    class="md:hidden fixed inset-0 z-40 bg-night/40 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300"
    data-menu-overlay
  ></div>
  <nav
    class="md:hidden fixed top-0 right-0 z-50 h-full w-[82%] max-w-sm translate-x-full bg-cream shadow-2xl transition-transform duration-400 ease-[cubic-bezier(0.16,1,0.3,1)] flex flex-col"
    data-menu-panel
    aria-label="Mobile"
  >
    <div class="flex items-center justify-between px-6 py-5 border-b border-forest/10">
      <Logo />
      <button type="button" class="w-10 h-10 inline-flex items-center justify-center rounded-full text-forest" aria-label="Close menu" data-menu-close>
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg>
      </button>
    </div>
    <div class="flex-1 overflow-y-auto px-6 py-6 flex flex-col gap-1">
      {nav.map((item) => (
        <a href={item.href} class="py-3 text-lg font-display font-semibold text-forest border-b border-forest/5">{item.label}</a>
      ))}
    </div>
    <div class="px-6 py-6 flex flex-col gap-3 border-t border-forest/10">
      <a href={site.booking} target="_blank" rel="noopener" class="btn btn-primary w-full">Book online</a>
      <a href={`tel:${site.phoneHref}`} class="btn btn-outline w-full">Call {site.phoneDisplay}</a>
    </div>
  </nav>
</header>

<script>
  const header = document.querySelector('[data-header-bar]');
  const onScroll = () => {
    if (window.scrollY > 20) header?.classList.add('shadow-lg', '!bg-cream/90');
    else header?.classList.remove('shadow-lg', '!bg-cream/90');
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  const toggle = document.querySelector('[data-menu-toggle]');
  const panel = document.querySelector('[data-menu-panel]');
  const overlay = document.querySelector('[data-menu-overlay]');
  const closeEls = document.querySelectorAll('[data-menu-close], [data-menu-overlay]');
  const open = () => {
    panel?.classList.remove('translate-x-full');
    overlay?.classList.remove('opacity-0', 'pointer-events-none');
    toggle?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  };
  const close = () => {
    panel?.classList.add('translate-x-full');
    overlay?.classList.add('opacity-0', 'pointer-events-none');
    toggle?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  };
  toggle?.addEventListener('click', open);
  closeEls.forEach((el) => el.addEventListener('click', close));
  panel?.querySelectorAll('a').forEach((a) => a.addEventListener('click', close));
</script>
